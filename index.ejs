<!DOCTYPE html>
<html lang="mr">
<head>
    <meta charset="UTF-8">
    <title>Task 2 - Client & Server Validation</title>
</head>
<!-- Inline Style वापरून बॅकग्राउंड सेट केले आहे -->
<body style="font-family: 'Segoe UI', sans-serif; background: #f3f4f6; margin: 0; padding: 50px; display: flex; justify-content: center; align-items: center; min-height: 80vh;">

    <div style="background: white; width: 100%; max-width: 400px; padding: 30px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        <h2 style="color: #2563eb; text-align: center; margin-bottom: 25px;">Task 2: User Form</h2>
        
        <!-- Form: Submit होताना validateForm() फंक्शन चालणार -->
        <form action="/submit-data" method="POST" onsubmit="return validateForm()">
            
            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #374151;">Full Name:</label>
                <input type="text" id="fullName" name="fullName" style="width: 93%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 5px;">
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #374151;">Email Address:</label>
                <input type="text" id="email" name="email" style="width: 93%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 5px;">
            </div>

            <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: bold; margin-bottom: 5px; color: #374151;">Mobile Number:</label>
                <input type="text" id="mobile" name="mobile" style="width: 93%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 5px;">
            </div>

            <button type="submit" style="width: 100%; padding: 12px; background: #2563eb; color: white; border: none; border-radius: 5px; font-size: 16px; font-weight: bold; cursor: pointer;">Submit</button>
        </form>
    </div>

    <!-- 🔴 १. Client-Side Validation (Inline JavaScript Script) -->
    <script>
        function validateForm() {
            let name = document.getElementById("fullName").value.trim();
            let email = document.getElementById("email").value.trim();
            let mobile = document.getElementById("mobile").value.trim();

            // रकाने रिकामे आहेत का ते तपासणे
            if (name === "" || email === "" || mobile === "") {
                alert("Error: कृपया सर्व रकाने भरा!");
                return false;
            }

            // ईमेल मध्ये '@' आहे का तपासणे
            if (!email.includes("@")) {
                alert("Error: ईमेल मध्ये '@' असणे आवश्यक आहे!");
                return false;
            }

            // मोबाईल नंबर फक्त १० अंकी आहे का तपासणे
            if (mobile.length !== 10 || isNaN(mobile)) {
                alert("Error: मोबाईल नंबर अचूक १० अंकी संख्याच हवा!");
                return false;
            }

            return true; // सर्व बरोबर असेल तरच फॉर्म सबमिट होईल
        }
    </script>
</body>
</html>