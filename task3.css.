body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #f4f6f9;
}

.header {
    background-color: #2c3e50;
    color: white;
    text-align: center;
    padding: 30px 20px;
}

.container {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    padding: 30px;
    justify-content: center;
}

.card {
    background: white;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    width: 300px;
    box-sizing: border-box;
}

/* रेस्पॉन्सिव मीडिया क्वेरी (Mobile Rules) */
@media (max-width: 768px) {
    .container {
        flex-direction: column;
        align-items: center;
    }
    .card {
        width: 100%;
        max-width: 400px;
    }
}
